{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Uma instituição de ensino (SaaS Tenant).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nome": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["tenantId", "nome"]
    },
    "Usuario": {
      "title": "Usuario",
      "description": "Usuário da plataforma.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "perfil": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "tenantId", "perfil"]
    },
    "LaboratorioCategoria": {
      "title": "LaboratorioCategoria",
      "description": "Categoria organizacional de labs.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nome": { "type": "string" },
        "cursoId": { "type": "string" }
      },
      "required": ["tenantId", "nome"]
    },
    "IntegrationProviderConfig": {
      "title": "IntegrationProviderConfig",
      "description": "Configuração centralizada de integrações externas (AI, Payment, etc).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nomeProvedor": { "type": "string" },
        "categoria": { "type": "string", "enum": ["AI", "PAYMENT", "ANALYTICS", "COMMUNICATION"] },
        "subCategoria": { "type": "string", "enum": ["FREE", "HYBRID", "PREMIUM"] },
        "ambiente": { "type": "string", "enum": ["sandbox", "producao"] },
        "status": { "type": "string", "enum": ["ativo", "inativo", "standby"] },
        "prioridade": { "type": "number" },
        "fallbackPara": { "type": "string" },
        "chavePublicaMasked": { "type": "string" },
        "criadoPor": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["tenantId", "nomeProvedor", "categoria", "subCategoria"]
    },
    "IntegrationAuditLog": {
      "title": "IntegrationAuditLog",
      "description": "Log de auditoria absoluta para governança de integrações.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "acao": { "type": "string" }, // "CREATE", "UPDATE", "TOGGLE", "ROTATE"
        "userId": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
,
    "Gamificacao": {
      "title": "Gamificacao",
      "description": "Configurações e estados de gamificação.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "xpTotal": { "type": "number" },
        "badges": { "type": "array" }
      },
      "required": ["tenantId"]
    },
    "PerfilAluno": {
      "title": "PerfilAluno",
      "description": "Dados pedagógicos e de jornada do aluno.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "nivel": { "type": "number" },
        "xp": { "type": "number" }
      },
      "required": ["userId"]
    },
    "Simulador": {
      "title": "Simulador",
      "description": "Simulador educacional (lógica, código, decisão).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "titulo": { "type": "string" },
        "tipo": { "type": "string", "enum": ["LOGICA", "CODIGO", "DB", "REDES", "DECISAO"] },
        "cenario": { "type": "string" },
        "etapas": { "type": "array" },
        "createdBy": { "type": "string" }
      },
      "required": ["tenantId", "titulo", "tipo"]
    },
    "EstudoCaso": {
      "title": "EstudoCaso",
      "description": "Cenário de problema real para análise técnica.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "solucoesEsperadas": { "type": "array" }
      }
    },
    "AulaInvertida": {
      "title": "AulaInvertida",
      "description": "Configuração de materiais pré-aula e validação prévia.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "conteudoPre": { "type": "string" },
        "quizValidacao": { "type": "array" }
      }
    },
    "IndicadoresBI": {
      "title": "IndicadoresBI",
      "description": "BI agregado para dashboards institucionais.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "resumo": { "type": "object" }
      },
      "required": ["tenantId"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Instituições cadastradas no SaaS."
    },
    "/usuarios/{userId}": {
      "schema": "Usuario",
      "description": "Usuários do sistema."
    },
    "/laboratorio_categorias/{catId}": {
      "schema": "LaboratorioCategoria",
      "description": "Categorias de laboratórios por tenant."
    },
    "/config_integracoes/{configId}": {
      "schema": "IntegrationProviderConfig",
      "description": "Configurações unificadas de integrações externas."
    },
    "/audit_integracoes/{logId}": {
      "schema": "IntegrationAuditLog",
      "description": "Logs de auditoria de integrações."
    },
    "/simuladores/{simId}": {
      "schema": "Simulador",
      "description": "Banco de simuladores pedagógicos."
    },
    "/estudos_caso/{caseId}": {
      "schema": "EstudoCaso",
      "description": "Repositório de estudos de caso reais."
    },
    "/aulas_invertidas/{aulaId}": {
      "schema": "AulaInvertida",
      "description": "Gestão de conteúdos pré-aula."
    },
    "/gamificacao/{gamificacaoId}": {
      "schema": "Gamificacao",
      "description": "Configurações de gamificação por tenant."
    },
    "/perfis_aluno/{userId}": {
      "schema": "PerfilAluno",
      "description": "Dados pedagógicos e gamificados do aluno."
    },
    "/indicadores_bi/{biId}": {
      "schema": "IndicadoresBI",
      "description": "BI agregado para dashboards institucionais."
    }
  }

}
