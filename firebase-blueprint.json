{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Uma instituição de ensino (SaaS Tenant).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nome": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["tenantId", "nome"]
    },
    "Usuario": {
      "title": "Usuario",
      "description": "Usuário da plataforma.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "perfil": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "tenantId", "perfil"]
    },
    "LaboratorioCategoria": {
      "title": "LaboratorioCategoria",
      "description": "Categoria organizacional de labs.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nome": { "type": "string" },
        "cursoId": { "type": "string" }
      },
      "required": ["tenantId", "nome"]
    },
    "IntegrationProviderConfig": {
      "title": "IntegrationProviderConfig",
      "description": "Configuração centralizada de integrações externas (AI, Payment, etc).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "nomeProvedor": { "type": "string" },
        "categoria": { "type": "string", "enum": ["AI", "PAYMENT", "ANALYTICS", "COMMUNICATION"] },
        "subCategoria": { "type": "string", "enum": ["FREE", "HYBRID", "PREMIUM"] },
        "ambiente": { "type": "string", "enum": ["sandbox", "producao"] },
        "status": { "type": "string", "enum": ["ativo", "inativo", "standby"] },
        "prioridade": { "type": "number" },
        "fallbackPara": { "type": "string" },
        "chavePublicaMasked": { "type": "string" },
        "criadoPor": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["tenantId", "nomeProvedor", "categoria", "subCategoria"]
    },
    "IntegrationAuditLog": {
      "title": "IntegrationAuditLog",
      "description": "Log de auditoria absoluta para governança de integrações.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "acao": { "type": "string" }, // "CREATE", "UPDATE", "TOGGLE", "ROTATE"
        "userId": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
,
    "Gamificacao": {
      "title": "Gamificacao",
      "description": "Configurações e estados de gamificação.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "xpTotal": { "type": "number" },
        "badges": { "type": "array" }
      },
      "required": ["tenantId"]
    },
    "PerfilAluno": {
      "title": "PerfilAluno",
      "description": "Dados pedagógicos e de jornada do aluno.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "nivel": { "type": "number" },
        "xp": { "type": "number" }
      },
      "required": ["userId"]
    },
    "Simulador": {
      "title": "Simulador",
      "description": "Simulador educacional (lógica, código, decisão).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "titulo": { "type": "string" },
        "tipo": { "type": "string", "enum": ["LOGICA", "CODIGO", "DB", "REDES", "DECISAO"] },
        "cenario": { "type": "string" },
        "etapas": { "type": "array" },
        "createdBy": { "type": "string" }
      },
      "required": ["tenantId", "titulo", "tipo"]
    },
    "EstudoCaso": {
      "title": "EstudoCaso",
      "description": "Cenário de problema real para análise técnica.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "solucoesEsperadas": { "type": "array" }
      }
    },
    "AulaInvertida": {
      "title": "AulaInvertida",
      "description": "Configuração de materiais pré-aula e validação prévia.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "conteudoPre": { "type": "string" },
        "quizValidacao": { "type": "array" }
      }
    },
    "IndicadoresBI": {
      "title": "IndicadoresBI",
      "description": "BI agregado para dashboards institucionais.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "resumo": { "type": "object" }
      },
      "required": ["tenantId"]
    },
    "DigitalTwin": {
      "title": "DigitalTwin",
      "description": "Gêmeo digital analítico do aluno.",
      "type": "object",
      "properties": {
        "alunoId": { "type": "string" },
        "nivel": { "type": "string" },
        "engajamento": { "type": "number" },
        "riscoPedagogico": { "type": "string" },
        "velocidadeAprendizagem": { "type": "number" },
        "previsoes": { "type": "object" },
        "lastUpdate": { "type": "string" }
      },
      "required": ["alunoId"]
    },
    "BehavioralLog": {
      "title": "BehavioralLog",
      "description": "Log de comportamento educacional do aluno.",
      "type": "object",
      "properties": {
        "alunoId": { "type": "string" },
        "tipo": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["alunoId", "tipo"]
    },
    "AIFeedback": {
      "title": "AIFeedback",
      "description": "Feedback de qualidade sobre as respostas da IA.",
      "type": "object",
      "properties": {
        "agent": { "type": "string" },
        "prompt": { "type": "string" },
        "response": { "type": "string" },
        "score": { "type": "number" },
        "observation": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["agent", "score"]
    },
    "RAGDocument": {
      "title": "RAGDocument",
      "description": "Documento institucional para base de conhecimento regional.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sourceType": { "type": "string" },
        "ownerId": { "type": "string" },
        "visibility": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "MarketplaceContent": {
      "title": "MarketplaceContent",
      "description": "Conteúdo educacional compartilhado no ecossistema.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "contentType": { "type": "string" },
        "content": { "type": "object" },
        "visibility": { "type": "string" },
        "rating": { "type": "number" },
        "downloads": { "type": "number" },
        "tags": { "type": "array" }
      }
    },
    "TenantAIConfig": {
      "title": "TenantAIConfig",
      "description": "Configuração WhiteLabel da IA por cliente/escola.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "assistantName": { "type": "string" },
        "tone": { "type": "string" },
        "primaryModel": { "type": "string" },
        "enabledAgents": { "type": "array" },
        "safetyLevel": { "type": "string" }
      }
    },
    "AIAuditLog": {
      "title": "AIAuditLog",
      "description": "Log de auditoria para conformidade e transparência.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "userId": { "type": "string" },
        "agentName": { "type": "string" },
        "modelUsed": { "type": "string" },
        "blocked": { "type": "boolean" },
        "safetyScore": { "type": "number" },
        "estimatedCost": { "type": "number" }
      }
    }
  },
