rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function getUserData() { 
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data 
        : null; 
    }
    
    function isAdmin() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'ADMIN'; }
    function isProfessor() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'PROFESSOR'; }
    function isStudent() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'ALUNO'; }
    function isCoordinator() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'COORDINATOR'; }
    
    function hasPermission(perm) {
      let data = getUserData();
      return (data != null && data.permissoesGranulares != null && data.permissoesGranulares.hasAny([perm]));
    }
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidUser(data) {
      return data.nome is string && data.nome.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.perfil in ['ADMIN', 'PROFESSOR', 'ALUNO'] &&
             data.status in ['ATIVO', 'INATIVO'];
    }

    function isValidQuestion(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.difficulty in ['easy', 'medium', 'hard'] &&
             data.ucId is string && data.ucId.size() <= 50;
    }

    // --- Collections ---

    // USERS
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) && isVerified() && isValidUser(incoming())) || isAdmin();
      allow update: if isSignedIn() && (
        (isAdmin() && isValidUser(incoming())) ||
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'telefone', 'fotoUrl', 'updatedAt']) && incoming().updatedAt == request.time)
      );
    }

    // PROFILES & PERMISSIONS
    match /perfis/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // AUDIT LOGS
    match /logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // INVITATIONS
    match /convites/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // EXAMS & SIMULATIONS
    match /questoes/{qId} {
      allow read: if isSignedIn();
      allow create: if isProfessor() && isValidQuestion(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if (isProfessor() && existing().createdBy == request.auth.uid && isValidQuestion(incoming())) || isAdmin();
      allow delete: if isAdmin() || (isProfessor() && existing().createdBy == request.auth.uid);
    }

    // SITUATIONS OF LEARNING (SA)
    match /situacoes_aprendizagem/{saId} {
      allow read: if isSignedIn();
      allow create: if isProfessor() && incoming().createdBy == request.auth.uid;
      allow update: if (isProfessor() && existing().createdBy == request.auth.uid) || isAdmin();
      allow delete: if (isProfessor() && existing().createdBy == request.auth.uid) || isAdmin();
    }

    match /recomendacoes/{recId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isProfessor() || isAdmin());
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) || isAdmin();
    }

    match /materiais_apoio/{matId} {
      allow read: if isSignedIn();
      allow write: if isProfessor() || isAdmin();
    }

    match /relatorios/{repId} {
      allow read: if isProfessor() || isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isProfessor() || isAdmin();
    }
    match /gamificacao/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isProfessor());
      allow write: if isAdmin(); // Only system/admin updates XP
    }

    match /ranking/{rankId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // TOKENS IA (Strict control)
    match /uso_ia/{usageId} {
      // Allow read if user is the owner, or if admin/professor
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isProfessor());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid; 
    }

    // NOTIFICATIONS & INTERNAL MESSAGES
    match /notificacoes/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (isAdmin() || isCoordinator() || isProfessor());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /mensagens_internas/{msgId} {
      allow read: if isSignedIn(); // Filtering happens on client via Queries (targetTurmaIds, targetRoles)
      allow write: if isAdmin() || isCoordinator() || isProfessor();
    }

    // MISSIONS & PROGRESS
    match /metas/{metaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /progresso_missoes/{progressId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow write: if isSignedIn() && incoming().userId == request.auth.uid; // Allows students to self-update progress (ideally handled by functions, but for this demo it's allowed)
    }

    match /conquistas_aluno/{conqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // DEFAULT BLANKET RULES FOR OTHER COLLECTIONS (Restricted to Sign-In)
    // ARQUITETURA PEDAGÓGICA AVANÇADA (CURSOS, TURMAS, UCs, VÍNCULOS)
    match /cursos/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isCoordinator() || hasPermission('gerenciar_cursos'); 
    }
    match /turmas/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isCoordinator() || hasPermission('gerenciar_turmas'); 
    }
    match /unidades_curriculares/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isCoordinator() || hasPermission('gerenciar_cursos'); 
    }
    match /vinculos_academicos/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isCoordinator() || hasPermission('gerenciar_turmas'); 
    }
    
    match /capacidades_tecnicas/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isCoordinator() || hasPermission('gerenciar_pedagogico'); 
    }
    
    // BUSINESS INTELLIGENCE (N8N Dashboards)
    match /indicadores_bi/{id} {
      allow read: if isAdmin() || isCoordinator();
      allow write: if false; // Written by Cloud Worker / N8n
    }
    
    // MOTOR INTELIGENTE DE APRENDIZAGEM & ADAPTAÇÃO
    match /perfil_aluno/{id} {
      allow read: if isSignedIn() && (id == request.auth.uid || isProfessor() || isAdmin() || isCoordinator());
      allow write: if isAdmin() || isCoordinator(); // Escrita automatizada por backend
    }
    
    match /planos_estudo/{id} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isProfessor() || isAdmin() || isCoordinator());
      allow write: if isProfessor() || isAdmin() || isCoordinator();
    }
    
    match /alertas_pedagogicos/{id} {
      allow read: if isSignedIn() && (resource.data.targetProfessorId == request.auth.uid || isAdmin() || isCoordinator());
      allow write: if isAdmin() || isCoordinator(); 
    }
    
    match /historico_decisoes_motor/{id} {
      allow read: if isAdmin() || isCoordinator();
      allow write: if isAdmin() || isCoordinator();
    }
    
  }
}
