rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function getUserData() { 
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data 
        : null; 
    }
    
    function isAdmin() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'ADMIN'; }
    function isProfessor() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'PROFESSOR'; }
    function isStudent() { return isSignedIn() && getUserData() != null && getUserData().perfil == 'ALUNO'; }
    
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Schema Validations
    function isValidGamificationProfile(data) {
      return data.alunoId == request.auth.uid &&
             data.nivelAtual is number && data.nivelAtual >= 1 &&
             data.xpAtual is number && data.xpAtual >= 0;
    }

    function isValidMission(data) {
      return data.titulo is string && data.titulo.size() <= 200 &&
             data.tipo in ['DIARIA', 'SEMANAL', 'ESPECIAL', 'ADAPTATIVA'] &&
             data.pontos is number && data.xp is number;
    }

    function isValidGoal(data) {
      return data.alunoId is string && data.alunoId.size() <= 128 &&
             data.progressoAtual is number && data.progressoMeta is number &&
             data.status in ['EM_ANDAMENTO', 'CONCLUIDA', 'FALHA'] &&
             data.keys().hasAll(['alunoId', 'titulo', 'tipoMeta', 'origem', 'progressoAtual', 'progressoMeta', 'status', 'updatedAt']);
    }

    function isValidEvent(data) {
      return data.alunoId == request.auth.uid &&
             data.tipoEvento is string && data.tipoEvento.size() <= 100 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // 1. USUÁRIOS
    match /usuarios/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || isProfessor());
      allow create: if (isOwner(userId) && isVerified()) || isAdmin();
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'telefone', 'fotoUrl', 'updatedAt'])));
    }

    // 2. GAMIFICAÇÃO PERFIL (Resumo)
    match /gamificacao/{alunoId} {
      allow get: if isSignedIn() && isValidId(alunoId) && (isOwner(alunoId) || isAdmin() || isProfessor());
      allow list: if isSignedIn() && (isAdmin() || isProfessor());
      // Apenas Admin ou Backend (Worker) pode atualizar XP/Pontos reais
      allow write: if isAdmin();
    }

    // 3. TRILHAS E ESTRUTURA
    match /trilhas_gamificadas/{trilhaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }
    match /fases_trilha/{faseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // 4. MISSÕES E DESAFIOS
    match /missoes/{missaoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }
    match /gamificacao_missoes/{missaoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }
    match /gamificacao_progresso_missoes/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
    match /desafios/{desafioId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }
    match /boss_challenges/{bossId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // 5. CONQUISTAS E BADGES
    match /conquistas/{conqId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. RANKING (Snapshots)
    match /ranking/{rankId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 7. METAS E STREAKS
    match /metas/{metaId} {
      allow get: if isSignedIn() && isValidId(metaId) && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow list: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow create: if isSignedIn() && isVerified() && incoming().alunoId == request.auth.uid && isValidGoal(incoming());
      allow update: if isSignedIn() && isVerified() && existing().alunoId == request.auth.uid && isValidGoal(incoming()) && (
        // Apenas progresso e status podem mudar pelo aluno
        incoming().diff(existing()).affectedKeys().hasOnly(['progressoAtual', 'status', 'updatedAt'])
      );
    }
    match /streaks/{streakId} {
      allow get: if isSignedIn() && isValidId(streakId) && (resource.data.alunoId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // System managed
    }

    // 8. HISTÓRICO E LEDGER (Imutável)
    match /historico_pontos/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow create: if isAdmin(); 
      allow update, delete: if false; 
    }
    match /historico_xp/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    match /bonus_tokens/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // 9. PROGRESSO (State Tracking)
    match /progresso_trilha/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin();
    }
    match /progresso_missao/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin();
    }
    match /progresso_desafio/{id} {
      allow read: if isSignedIn() && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin();
    }

    match /notificacoes/{id} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || isProfessor();
      allow update: if isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // 10. NOTIFICAÇÕES E EVENTOS
    match /notificacoes_gamificacao/{id} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || isProfessor();
      allow update: if isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
    match /eventos_gamificacao/{eventId} {
      allow get: if isAdmin() && isValidId(eventId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && isVerified() && isValidEvent(incoming()) && isValidId(eventId);
      allow update, delete: if false; // Eventos são fatos imutáveis
    }

    // 11. CONFIGURAÇÕES E LOGS
    match /configuracoes_gamificacao/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /logs_gamificacao/{id} {
      allow read: if isAdmin() || isProfessor();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- Outras Coleções (Pedagógico e Administrativo) ---
    match /cursos/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /turmas/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /unidades_curriculares/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /vinculos_academicos/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questoes/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isProfessor(); }
    match /situacoes_aprendizagem/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isProfessor(); }
    
    // Novas coleções SaaS, BI e Adaptativo
    match /indicadores_bi/{id} {
      allow read: if isAdmin() || isProfessor();
      allow write: if isAdmin();
    }
    match /perfil_aluno/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isProfessor());
      allow list: if isAdmin() || isProfessor();
      allow write: if isAdmin();
    }
    match /assinaturas/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow write: if isAdmin();
    }
    match /pagamentos/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow write: if isAdmin();
    }
    match /configuracoes_institucionais/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }


    match /planos_estudo/{id} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin() || isProfessor());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
  }
}

