rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Add tenants rule explicitly
    match /tenants/{id} {
      allow read: if isSignedIn();
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function getUserDoc() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)) 
        : null;
    }
    
    function hasTenant() {
      return isSignedIn() && getUserDoc() != null && getUserDoc().data.tenantId != null;
    }

    function getTenantId() { 
      return hasTenant() ? getUserDoc().data.tenantId : 'no-tenant'; 
    }
    
    function isAdmin() { return isSignedIn() && getUserDoc() != null && getUserDoc().data.perfil == 'ADMIN'; }
    function isProfessor() { return isSignedIn() && getUserDoc() != null && getUserDoc().data.perfil == 'PROFESSOR'; }
    
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isTenantMember() { return hasTenant(); }
    
    // Helper to validate tenantId access and implicit assignment
    function validateTenantAccess(data) {
      return data.tenantId == getTenantId();
    }

    // 1. USUÁRIOS
    match /usuarios/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && isVerified()) || isAdmin();
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'telefone', 'fotoUrl', 'updatedAt'])));
    }

    // 2. PEDAGÓGICO
    match /avaliacoes/{id} {
      allow read: if isTenantMember() && get(/databases/$(database)/documents/avaliacoes/$(id)).data.tenantId == getTenantId();
      allow write: if (isAdmin() || isProfessor()) && validateTenantAccess(incoming());
    }
    match /cursos/{id} { 
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if isAdmin() && validateTenantAccess(incoming()); 
    }
    match /turmas/{id} { 
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if isAdmin() && validateTenantAccess(incoming()); 
    }
    match /questoes/{id} { 
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if (isAdmin() || isProfessor()) && validateTenantAccess(incoming()); 
    }
    match /situacoes_aprendizagem/{id} { 
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if (isAdmin() || isProfessor()) && validateTenantAccess(incoming()); 
    }
    
    // 3. GAMIFICAÇÃO
    match /gamificacao/{alunoId} {
      allow read: if isTenantMember() && (resource.data.tenantId == getTenantId()) && (alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
    match /progresso_missao/{id} {
      allow read: if isTenantMember() && (resource.data.tenantId == getTenantId()) && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
    match /missoes/{id} {
      allow read: if isTenantMember() && (resource.data.tenantId == getTenantId());
      allow write: if (isAdmin() || isProfessor()) && validateTenantAccess(incoming());
    }
    match /gamificacao_missoes_adaptativas/{id} {
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin() || isProfessor();
    }
    match /ranking/{id} {
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if isAdmin();
    }
    
    match /notificacoes_gamificacao/{id} {
      allow read: if isTenantMember() && (resource.data.tenantId == getTenantId()) && (resource.data.userId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
    
    // 4. LABORATÓRIOS PRÁTICOS
    match /laboratorios_praticos/{id} {
      allow read: if isTenantMember() && resource.data.tenantId == getTenantId();
      allow write: if (isAdmin() || isProfessor()) && validateTenantAccess(incoming());
    }
    match /execucoes_laboratorio/{id} {
      allow read: if isTenantMember() && (resource.data.tenantId == getTenantId()) && (resource.data.alunoId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isTenantMember() && validateTenantAccess(incoming()) && (incoming().alunoId == request.auth.uid || isAdmin() || isProfessor());
    }
    
    // ... Other existing rules - MUST be updated tenant-awareness similarly for security
    
  }
}
