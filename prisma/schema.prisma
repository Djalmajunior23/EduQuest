generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  domain           String?  @unique
  statusAssinatura String   @default("ATIVA")
  limiteAlunos     Int      @default(100)
  limiteTokens     Int      @default(100000)
  branding         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usuarios         Usuario[]
  cursos           Curso[]
  simulados        Simulado[]
  turmas           Turma[]
  badges           Badge[]
  instituicao      Instituicao?
  notificacoes     Notificacao[]
}

model Notificacao {
  id          String   @id @default(uuid())
  titulo      String
  mensagem    String
  lida        Boolean  @default(false)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  tipo        String   @default("INFO") // INFO, ALERTA, SUCESSO
  createdAt   DateTime @default(now())
}

model Instituicao {
  id          String   @id @default(uuid())
  nome        String
  cnpj        String?  @unique
  endereco    String?
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Usuario {
  id              String        @id @default(uuid())
  nome            String
  email           String        @unique
  senhaHash       String
  perfil          PerfilUsuario @default(ALUNO)
  ativo           Boolean       @default(true)
  deveTrocarSenha Boolean       @default(false)
  permissoes_granulares Json?
  tenantId        String?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id])
  turmaId         String?
  turma           Turma?        @relation(fields: [turmaId], references: [id])
  telefone        String?
  fotoUrl         String?
  ultimoLoginEm   DateTime?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  submissoes      Submissao[]
  conquistas      ConquistaUsuario[]
  logs            LogSistema[]
  auditoriaLogs   AuditoriaLog[]
  chats           ChatHistory[]
  notificacoes    Notificacao[]
  planosEstudo    PlanoEstudo[]
}

model AuditoriaLog {
  id          String   @id @default(uuid())
  acao        String   // CRIACAO, EDICAO, EXCLUSAO
  entidade    String   // ex: 'Usuario'
  entidadeId  String
  dadosAntigos Json?
  dadosNovos   Json?
  usuarioId   String?  // Quem fez a ação
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  ip          String?
  createdAt   DateTime @default(now())
}

model Competencia {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  cursoId     String
  curso       Curso    @relation(fields: [cursoId], references: [id])
  capacidades CapacidadeTecnica[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CapacidadeTecnica {
  id            String   @id @default(uuid())
  nome          String
  descricao     String?
  competenciaId String
  competencia   Competencia @relation(fields: [competenciaId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlanoEstudo {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  objetivos   String?  @db.Text
  conteudo    Json?    // Array de materiais/links
  progresso   Float    @default(0)
  status      String   @default("ATIVO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PerfilUsuario {
  ADMIN
  PROFESSOR
  ALUNO
  COORDENADOR
  GESTOR
  SUPORTE
}

model Turma {
  id          String   @id @default(uuid())
  nome        String
  anoLetivo   Int
  semestre    Int?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  cursoId     String
  curso       Curso    @relation(fields: [cursoId], references: [id])
  status      String   @default("ATIVA")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios    Usuario[]
}

model Curso {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  status      String   @default("ATIVO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  disciplinas Disciplina[]
  turmas      Turma[]
  competencias Competencia[]
}

model Disciplina {
  id          String   @id @default(uuid())
  nome        String
  cursoId     String
  curso       Curso    @relation(fields: [cursoId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unidades    UnidadeCurricular[]
}

model UnidadeCurricular {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  cargaHoraria Int      @default(0)
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  atividades  Atividade[]
}

model Atividade {
  id                  String   @id @default(uuid())
  titulo              String
  descricao           String
  tipo                String   // CODIGO, DISCURSIVA, SAEP
  unidadeCurricularId String
  unidadeCurricular   UnidadeCurricular @relation(fields: [unidadeCurricularId], references: [id])
  rubricas            Json?
  casosTeste          Json?
  status              String   @default("RASCUNHO")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  submissoes          Submissao[]
}

model Submissao {
  id                  String   @id @default(uuid())
  atividadeId         String
  atividade           Atividade @relation(fields: [atividadeId], references: [id])
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [id])
  codigoFont          String?
  respostaDiscursiva  String?
  status              String   @default("PENDENTE") // PENDENTE, CORRIGIDA, ERRO
  tempoGasto          Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  correcao            Correcao?
}

model Correcao {
  id            String   @id @default(uuid())
  submissaoId   String   @unique
  submissao     Submissao @relation(fields: [submissaoId], references: [id])
  nota          Float
  feedback      String   @db.Text
  competencias  Json?
  corrigidoPor  String?  // ID do usuario ou 'IA'
  createdAt     DateTime @default(now())
}

model Simulado {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  status      String   @default("ATIVO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questoes    Questao[]
}

model Questao {
  id          String   @id @default(uuid())
  enunciado   String   @db.Text
  tipo        String   // MULTIPLA_ESCOLHA, VERDADEIRO_FALSO
  simuladoId  String
  simulado    Simulado @relation(fields: [simuladoId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  alternativas Alternativa[]
}

model Alternativa {
  id          String   @id @default(uuid())
  texto       String
  correta     Boolean  @default(false)
  questaoId   String
  questao     Questao  @relation(fields: [questaoId], references: [id])
}

model Badge {
  id          String   @id @default(uuid())
  nome        String
  descricao   String
  icone       String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  usuarios    ConquistaUsuario[]
}

model ConquistaUsuario {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  badgeId     String
  badge       Badge    @relation(fields: [badgeId], references: [id])
  conquistadoEm DateTime @default(now())
}

model Ranking {
  id          String   @id @default(uuid())
  contexto    String   // TURMA, CURSO, GLOBAL
  contextoId  String?
  posicao     Int
  pontuacao   Float
  usuarioId   String
  updatedAt   DateTime @updatedAt
}

model ChatHistory {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  modelo      String?
  mensagens   Json     // Array de mensagens
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LogSistema {
  id          String   @id @default(uuid())
  acao        String
  detalhes    String?
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  ip          String?
  createdAt   DateTime @default(now())
}
